# MediCore AI — Backend Environment Variables
# Copy this to .env and fill in your values

# ─── Application ─────────────────────────────────────────────────────────────
SECRET_KEY=your-256-bit-secret-key-generate-with-openssl-rand-hex-32
ENVIRONMENT=development
DEBUG=true

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://medicore:medicore_dev_pass@localhost:5432/medicore
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_dev_pass@localhost:6379/0
REDIS_PASSWORD=redis_dev_pass

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_dev_pass@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_dev_pass@localhost:6379/2

# ─── Anthropic Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── AWS S3 (optional for local dev — files saved locally if not set) ────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
S3_BUCKET=medicore-studies

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://medicore.vercel.app"]
