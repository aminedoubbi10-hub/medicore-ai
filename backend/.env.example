ENVIRONMENT=development
APP_VERSION=2.4.1

# Local database defaults. For quick local dev you can use SQLite.
DATABASE_URL=sqlite+aiosqlite:///./medicore.db
REDIS_URL=redis://localhost:6379/0

# Generate your own long random value before real deployment.
SECRET_KEY=change-me-generate-a-long-random-secret

# Optional for AI-assisted report formatting and external model checks.
# Leave blank to run conservative deterministic safety gates only.
ANTHROPIC_API_KEY=

# Local + deployed frontend origins. Use comma-separated URLs, not JSON.
CORS_ORIGINS=http://localhost:3000,https://medicore-ai-lime.vercel.app
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

MAX_FILE_SIZE_MB=100
UPLOAD_DIR=uploads

