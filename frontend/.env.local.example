# Backend FastAPI URL.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional server-side ECG visual verification route.
# Use Gemini first because it has a useful free tier. Never prefix secrets with NEXT_PUBLIC_.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional paid fallback.
# Keep disabled unless you intentionally want paid Anthropic fallback.
ENABLE_ANTHROPIC_FALLBACK=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_VERSION=2023-06-01
